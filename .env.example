# =============================================================================
# Clearview Square — Environment Variables
# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.
# =============================================================================

# Contact form endpoint (leave blank if not using a form service)
VITE_FORM_ENDPOINT=

# Weather Widget API Key
# Get your free API key from: https://openweathermap.org/api
VITE_WEATHER_API_KEY=your-openweather-api-key-here

# -----------------------------------------------------------------------------
# Supabase (Phase 4 — CMS/Admin)
# The anon key is safe to include here — it is a public key protected by RLS.
# Find these values in: Supabase dashboard → Project Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Supabase Service Role Key
# FOR LOCAL SEED/ADMIN SCRIPTS ONLY. NEVER use the VITE_ prefix for this key.
# The VITE_ prefix causes Vite to bundle the value into the browser bundle,
# which would expose the service role key publicly. This key bypasses all RLS.
#
# Usage: node scripts/seed-supabase.js (Phase 4 only, local machine only)
# Never commit a real value. Never reference this in any src/ file.
# Find this in: Supabase dashboard → Project Settings → API → service_role (secret)
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=
